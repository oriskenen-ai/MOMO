# ========================================
# MTN MoMo Loans Platform - Configuration
# ========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ========================================
# Database Configuration
# ========================================
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mtn_momo_loans?retryWrites=true&w=majority

# ========================================
# Server Configuration
# ========================================
# Port where the server will run
PORT=3000

# Environment: development, staging, production
NODE_ENV=development

# ========================================
# OPTIONAL: Telegram Bot (for admin panel)
# ========================================
# If you want Telegram bot admin features, get a bot token from BotFather
# Leave empty or remove to disable Telegram bot
SUPER_ADMIN_BOT_TOKEN=

# List of super admin Telegram IDs (comma-separated)
# Default: ADMIN001
SUPER_ADMINS=ADMIN001

# ========================================
# OPTIONAL: Deployment URLs
# ========================================
# Only needed if deploying to Render or other platforms
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
# APP_URL=https://your-app-domain.com

# ========================================
# How to Set Up
# ========================================
# 1. Create MongoDB Atlas account at mongodb.com/cloud/atlas
# 2. Create a cluster (free tier available)
# 3. Create database user and get connection string
# 4. Replace 'username:password' with your MongoDB credentials
# 5. Replace 'cluster' with your actual cluster name
# 6. Save this file as .env in the root directory
# 7. (Optional) Add Telegram bot token for admin features

# ========================================
# Example Values
# ========================================
# For local development:
# MONGODB_URI=mongodb://localhost:27017/mtn_momo_loans
#
# For MongoDB Atlas (recommended):
# MONGODB_URI=mongodb+srv://user123:pass123@cluster0.abc123.mongodb.net/mtn_momo_loans?retryWrites=true&w=majority
#
# For Telegram (optional):
# SUPER_ADMIN_BOT_TOKEN=123456789:ABCdefGHIjklmnoPQRstUVwxyz1234567890
